generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TrainingSession {
  id                String    @id @default(cuid())
  title             String
  status            String    @default("draft")
  sourceAudioPath   String?
  sourceTranscript  String?
  summary           String?
  deadline          DateTime?
  wecomWebhookUrl   String?
  demoMode          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  keyPoints         TrainingKeyPoint[]
  assignments       TrainingAssignment[]

  @@map("training_sessions")
}

model TrainingKeyPoint {
  id          String  @id @default(cuid())
  sessionId   String
  title       String
  description String?
  keywords    String?
  weight      Int     @default(1)

  session     TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("training_key_points")
}

model Employee {
  id            String @id @default(cuid())
  name          String
  team          String?
  phone         String?
  employeeCode  String?
  wecomUserId   String?
  isActive      Boolean @default(true)

  assignments   TrainingAssignment[]

  @@map("employees")
}

model TrainingAssignment {
  id          String    @id @default(cuid())
  sessionId   String
  employeeId  String
  uniqueToken String    @unique @default(cuid())
  pushedAt    DateTime?
  openedAt    DateTime?
  repliedAt   DateTime?
  status      String    @default("not_started")

  session     TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reply       EmployeeReply?

  @@unique([sessionId, employeeId])
  @@map("training_assignments")
}

model EmployeeReply {
  id            String    @id @default(cuid())
  assignmentId  String    @unique
  audioPath     String?
  transcript    String?
  submittedAt   DateTime  @default(now())

  assignment    TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  analysis      UnderstandingAnalysis?

  @@map("employee_replies")
}

model UnderstandingAnalysis {
  id                    String   @id @default(cuid())
  replyId               String   @unique
  coverageScore         Int?
  accuracyScore         Int?
  overallScore          Int?
  level                 String?
  coveredPoints         String?
  missingPoints         String?
  wrongPoints           String?
  riskLevel             String?
  summary               String?
  correctionSuggestion  String?
  rawAiResult           String?
  createdAt             DateTime @default(now())

  reply                 EmployeeReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@map("understanding_analyses")
}

// ========== 配置管理表 ==========

model ModelProvider {
  id            String    @id @default(cuid())
  key           String    @unique
  displayName   String
  description   String?
  capabilities  String    @default("[]")
  defaultBaseUrl String?
  createdAt     DateTime  @default(now())

  connections   ModelConnection[]

  @@map("model_providers")
}

model ModelConnection {
  id            String    @id @default(cuid())
  providerId    String
  displayName   String
  baseUrl       String?
  apiKeyRef     String
  modelName     String
  isDefault     Boolean   @default(false)
  enabled       Boolean   @default(true)
  capabilities  String    @default("[]")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  provider      ModelProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  agentSpecs    AgentSpec[]

  @@map("model_connections")
}

model AgentSpec {
  id                String    @id @default(cuid())
  agentKey          String    @unique
  displayName       String
  description       String?
  capability        String
  modelConnectionId String?
  enabled           Boolean   @default(true)
  config            String    @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  modelConnection   ModelConnection? @relation(fields: [modelConnectionId], references: [id])

  @@map("agent_specs")
}

model ExternalContact {
  id             String   @id @default(cuid())
  externalUserId String   @unique
  name           String
  avatar         String?
  followUserId   String
  followUserName String?
  type           Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("external_contacts")
}

model ServiceConfig {
  id          String    @id @default(cuid())
  serviceKey  String    @unique
  displayName String
  config      String    @default("{}")
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("service_configs")
}
